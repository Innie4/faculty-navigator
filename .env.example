# FindMyBlock — environment configuration
# Copy this file to ".env" and fill in the values below.
# (The server reads these at startup; .env is git-ignored.)

# Port the web server listens on.
PORT=3000

# API write key. When set, every data-write endpoint (add/edit/delete
# buildings, nodes, edges, POIs) requires an "x-api-key" header matching
# this value. Leave blank/unset to run in open/dev mode (no auth).
API_KEY=

# Path to the SQLite database file. Leave blank to use ./faculty.db.
FACULTY_DB_PATH=
